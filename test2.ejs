<!DOCTYPE html>

<html dir="rtl" lang="fa">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>اطلاعات اشتراک</title>
<style>
        @font-face {
            font-family: 'IRANSans';
            src: url('https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/dist/Vazirmatn-Regular.woff2') format('woff2');
            font-weight: normal;
            font-style: normal;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'IRANSans', Arial, sans-serif;
            background: #0a0a12;
            color: white;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        /* Decorative background elements */
        .bg-circle {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
        }

        .bg-circle-1 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(128, 0, 255, 0.15) 0%, rgba(128, 0, 255, 0.05) 70%, transparent 100%);
            top: -200px;
            right: -200px;
        }

        .bg-circle-2 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0, 183, 255, 0.15) 0%, rgba(0, 183, 255, 0.05) 70%, transparent 100%);
            bottom: -300px;
            left: -200px;
        }

        .dashboard {
            width: 100%;
            max-width: 1100px;
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 25px;
            position: relative;
            z-index: 1;
        }

        @media (max-width: 900px) {
            .dashboard {
                grid-template-columns: 1fr;
            }
        }

        .sidebar {
            background: rgba(20, 20, 35, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            position: relative;
            overflow: hidden;
        }

        .sidebar::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg,
                    rgba(128, 0, 255, 0.1) 0%,
                    rgba(0, 183, 255, 0.1) 100%);
            opacity: 0.2;
            z-index: -1;
        }

        .profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .profile-icon {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            position: relative;
            overflow: hidden;
        }

        .profile-icon::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg,
                    rgba(128, 0, 255, 0.3) 0%,
                    rgba(0, 183, 255, 0.3) 100%);
            opacity: 0.5;
        }

        .profile-icon svg {
            width: 40px;
            height: 40px;
            fill: white;
            position: relative;
            z-index: 1;
        }

        .profile-title {
            font-size: 22px;
            font-weight: bold;
            margin: 10px 0 5px;
            background: linear-gradient(to right, #ffffff, #b8c7ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .profile-id {
            color: rgba(255, 255, 255, 0.6);
            font-size: 14px;
        }

        .status-section {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 16px;
        }

        .status-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 14px;
        }

        .status-value {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #00ff88;
            box-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
        }

        .status-text {
            font-weight: bold;
            color: #00ff88;
        }

        .expiry-section {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 16px;
        }

        .expiry-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 14px;
            margin-bottom: 10px;
        }

        .expiry-value {
            font-size: 24px;
            font-weight: bold;
            color: #00b7ff;
        }

        .expiry-unit {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
        }

        .connection-buttons {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-top: auto;
        }

        .connection-btn {
            background: rgba(255, 255, 255, 0.05);
            border: none;
            border-radius: 16px;
            padding: 15px;
            color: white;
            font-family: 'IRANSans', Arial, sans-serif;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .connection-btn::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg,
                    rgba(128, 0, 255, 0.2) 0%,
                    rgba(0, 183, 255, 0.2) 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .connection-btn:hover::before {
            opacity: 1;
        }

        .connection-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .main-content {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
        }

        .stat-card {
            background: rgba(20, 20, 35, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 40px;
            border-radius: 0 4px 4px 0;
        }

        .download-card::before {
            background: linear-gradient(to bottom, #00b7ff, #0080ff);
        }

        .upload-card::before {
            background: linear-gradient(to bottom, #ff00aa, #8000ff);
        }

        .stat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .stat-title {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.7);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stat-icon {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .download-icon {
            background: rgba(0, 183, 255, 0.1);
            color: #00b7ff;
        }

        .upload-icon {
            background: rgba(128, 0, 255, 0.1);
            color: #8000ff;
        }

        .stat-value {
            font-size: 32px;
            font-weight: bold;
        }

        .download-value {
            color: #00b7ff;
        }

        .upload-value {
            color: #ff00aa;
        }

        .usage-card {
            background: rgba(20, 20, 35, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .usage-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
        }

        .usage-title {
            font-size: 18px;
            font-weight: bold;
            color: white;
        }

        .usage-stats {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .usage-stat {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .usage-label {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
        }

        .usage-value {
            font-size: 18px;
            font-weight: bold;
        }

        .used-value {
            color: #00b7ff;
        }

        .remaining-value {
            color: #ff00aa;
        }

        .progress-container {
            width: 100%;
            height: 8px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar {
            height: 100%;
            width: 60%;
            background: linear-gradient(to right, #00b7ff, #8000ff);
            border-radius: 4px;
            position: relative;
        }

        .progress-bar::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(90deg,
                    rgba(255, 255, 255, 0) 0%,
                    rgba(255, 255, 255, 0.3) 50%,
                    rgba(255, 255, 255, 0) 100%);
            animation: shine 2s infinite;
        }

        @keyframes shine {
            0% {
                transform: translateX(-100%);
            }

            100% {
                transform: translateX(100%);
            }
        }

        .connections-card {
            background: rgba(20, 20, 35, 0.4);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .connections-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 25px;
        }

        .connections-title {
            font-size: 18px;
            font-weight: bold;
            color: white;
        }

        .copy-all {
            background: rgba(255, 255, 255, 0.05);
            border: none;
            border-radius: 12px;
            padding: 10px 15px;
            color: white;
            font-family: 'IRANSans', Arial, sans-serif;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .copy-all:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .connection-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .connection-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s ease;
        }

        .connection-item:hover {
            background: rgba(255, 255, 255, 0.08);
            transform: translateX(-5px);
        }

        .connection-name {
            font-weight: bold;
        }

        .copy-btn {
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .copy-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }
